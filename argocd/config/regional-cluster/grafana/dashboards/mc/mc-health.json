{
  "title": "MC Health",
  "uid": "mc-health",
  "description": "Management Cluster health dashboard. Select an MC from the cluster dropdown to view HCP counts, SLA, HyperShift component health, node health, Karpenter provisioning, and Kubernetes workload health for that MC.",
  "tags": ["management-cluster", "mc", "health", "sre"],
  "timezone": "browser",
  "refresh": "1m",
  "schemaVersion": 38,
  "graphTooltip": 1,
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "current": { "text": "Thanos", "value": "Thanos" },
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "cluster",
        "type": "query",
        "label": "Management Cluster",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(up{cluster_type=~\"management.*\"}, cluster)",
        "refresh": 2,
        "multi": false,
        "includeAll": false,
        "sort": 1
      },
      {
        "name": "mc_namespaces",
        "type": "custom",
        "label": "MC Namespaces",
        "query": "hypershift|maestro-agent|cert-manager|external-secrets|vector",
        "current": {
          "text": "hypershift|maestro-agent|cert-manager|external-secrets|vector",
          "value": "hypershift|maestro-agent|cert-manager|external-secrets|vector"
        },
        "hide": 2,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "MC Overview",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Total HCPs",
      "description": "Total Hosted Control Planes running on this Management Cluster.",
      "gridPos": { "x": 0, "y": 1, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(hcp:hostedcluster_available{cluster=~\"$cluster\"}) or vector(0)",
          "legendFormat": "HCPs"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "HCPs Available",
      "description": "HCPs on this MC currently reporting as available (KubeAPIServerAvailable = True).",
      "gridPos": { "x": 5, "y": 1, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(hcp:hostedcluster_available{cluster=~\"$cluster\"} == 1) or vector(0)",
          "legendFormat": "Available"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "HCPs Unavailable",
      "description": "HCPs on this MC reporting as unavailable, excluding clusters that are installing or being deleted.",
      "gridPos": { "x": 10, "y": 1, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(hcp:hostedcluster_available{cluster=~\"$cluster\"} == 0 unless on(namespace) hcp:lifecycle_installing{cluster=~\"$cluster\"} unless on(namespace) hcp:lifecycle_deleting{cluster=~\"$cluster\"}) or vector(0)",
          "legendFormat": "Unavailable"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "HCPs Installing",
      "description": "HCPs on this MC currently waiting for initial availability.",
      "gridPos": { "x": 15, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(hcp:lifecycle_installing{cluster=~\"$cluster\"}) or vector(0)",
          "legendFormat": "Installing"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "HCPs Deleting",
      "description": "HCPs on this MC currently being deleted.",
      "gridPos": { "x": 19, "y": 1, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(hcp:lifecycle_deleting{cluster=~\"$cluster\"}) or vector(0)",
          "legendFormat": "Deleting"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" }
            ]
          }
        }
      }
    },
    {
      "id": 200,
      "type": "row",
      "title": "HCP SLA",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Median HCP Availability (30d)",
      "description": "Median 30-day availability across HCPs on this MC. The SLA target is 99.95%.",
      "gridPos": { "x": 0, "y": 6, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "quantile(0.5, min by (namespace) (avg_over_time(hcp:hostedcluster_available{cluster=~\"$cluster\"}[30d]))) * 100",
          "legendFormat": "Median Availability"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 3,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 99.9, "color": "yellow" },
              { "value": 99.95, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Median Error Budget Remaining",
      "description": "Median error budget remaining across HCPs on this MC. 100% means no availability loss; 0% means the 99.95% SLA budget is fully consumed over 30 days.",
      "gridPos": { "x": 6, "y": 6, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "(quantile(0.5, min by (namespace) (avg_over_time(hcp:hostedcluster_available{cluster=~\"$cluster\"}[30d]))) - 0.9995) / (1 - 0.9995) * 100",
          "legendFormat": "Error Budget"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 25, "color": "yellow" },
              { "value": 50, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "HCPs Below SLA Target",
      "description": "Number of HCPs on this MC whose 30-day availability is below the 99.95% SLA target.",
      "gridPos": { "x": 12, "y": 6, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(min by (namespace) (avg_over_time(hcp:hostedcluster_available{cluster=~\"$cluster\"}[30d])) < 0.9995) or vector(0)",
          "legendFormat": "Below SLA"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "HCP Availability Distribution (30d)",
      "description": "30-day availability for each HCP on this MC. Outliers indicate problem clusters on this specific MC.",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "min by (namespace) (avg_over_time(hcp:hostedcluster_available{cluster=~\"$cluster\"}[30d])) * 100",
          "legendFormat": "{{ namespace }}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 3,
          "min": 99,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 0,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 99.95, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Median Error Budget Burn Rate",
      "description": "Median error budget remaining over time for HCPs on this MC. A downward trend indicates availability degradation consuming the error budget.",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "(quantile(0.5, min by (namespace) (avg_over_time(hcp:hostedcluster_available{cluster=~\"$cluster\"}[30d]))) - 0.9995) / (1 - 0.9995) * 100",
          "legendFormat": "Median Error Budget %"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 25, "color": "yellow" },
              { "value": 50, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 300,
      "type": "row",
      "title": "HyperShift Components",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Pods Running",
      "description": "Number of pods in Running phase across MC platform namespaces (HyperShift, Maestro Agent, cert-manager, etc.).",
      "gridPos": { "x": 0, "y": 19, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(kube_pod_status_phase{phase=\"Running\", namespace=~\"$mc_namespaces\", cluster=~\"$cluster\"}) or vector(0)",
          "legendFormat": "Running"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Pods Not Ready",
      "description": "Pods in MC platform namespaces that are not in a Ready state.",
      "gridPos": { "x": 6, "y": 19, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(kube_pod_status_ready{condition=\"false\", namespace=~\"$mc_namespaces\", cluster=~\"$cluster\"}) or vector(0)",
          "legendFormat": "Not Ready"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Container Restarts (1h)",
      "description": "Total container restarts across MC platform namespaces in the last hour.",
      "gridPos": { "x": 12, "y": 19, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=~\"$mc_namespaces\", cluster=~\"$cluster\"}[1h])) or vector(0)",
          "legendFormat": "Restarts"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 5, "color": "yellow" },
              { "value": 20, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Pod Restarts by Namespace",
      "description": "Container restart rate per MC platform namespace. Helps identify which service is restarting.",
      "gridPos": { "x": 0, "y": 23, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (namespace) (increase(kube_pod_container_status_restarts_total{namespace=~\"$mc_namespaces\", cluster=~\"$cluster\"}[5m]))",
          "legendFormat": "{{ namespace }}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Pods Not Ready by Namespace",
      "description": "Count of not-ready pods per MC platform namespace over time.",
      "gridPos": { "x": 12, "y": 23, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (namespace) (kube_pod_status_ready{condition=\"false\", namespace=~\"$mc_namespaces\", cluster=~\"$cluster\"})",
          "legendFormat": "{{ namespace }}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 400,
      "type": "row",
      "title": "Node Health",
      "gridPos": { "x": 0, "y": 31, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 16,
      "type": "stat",
      "title": "Nodes Ready",
      "description": "Number of nodes in Ready condition on this MC.",
      "gridPos": { "x": 0, "y": 32, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(kube_node_status_condition{condition=\"Ready\", status=\"true\", cluster=~\"$cluster\"} == 1) or vector(0)",
          "legendFormat": "Ready"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 17,
      "type": "stat",
      "title": "Nodes Not Ready",
      "description": "Nodes not in Ready condition on this MC.",
      "gridPos": { "x": 6, "y": 32, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(kube_node_status_condition{condition=\"Ready\", status=\"true\", cluster=~\"$cluster\"} == 0) or vector(0)",
          "legendFormat": "Not Ready"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 18,
      "type": "stat",
      "title": "Max Node CPU Utilization",
      "description": "CPU utilization of the busiest node on this MC.",
      "gridPos": { "x": 12, "y": 32, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\", cluster=~\"$cluster\"}[5m]))) * 100",
          "legendFormat": "Max CPU %"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 80, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 19,
      "type": "stat",
      "title": "Max Node Memory Utilization",
      "description": "Memory utilization of the busiest node on this MC.",
      "gridPos": { "x": 18, "y": 32, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(1 - node_memory_MemAvailable_bytes{cluster=~\"$cluster\"} / node_memory_MemTotal_bytes{cluster=~\"$cluster\"}) * 100",
          "legendFormat": "Max Memory %"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 75, "color": "yellow" },
              { "value": 85, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 20,
      "type": "stat",
      "title": "Disk Pressure",
      "description": "Nodes on this MC with DiskPressure condition.",
      "gridPos": { "x": 0, "y": 36, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(kube_node_status_condition{condition=\"DiskPressure\", status=\"true\", cluster=~\"$cluster\"} == 1) or vector(0)",
          "legendFormat": "Disk Pressure"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
