{
  "title": "tmp-Platform Services (Prometheus)",
  "uid": "tmp-platform-svc-prom",
  "description": "Platform service metrics from YACE CloudWatch Exporter via Prometheus: IoT Core, NAT Gateway, Amazon MQ, and ACM certificate health. Mirror of the CloudWatch-native dashboard for comparison.",
  "tags": ["aws", "prometheus", "iot", "nat-gateway", "maestro", "networking", "sre", "yace"],
  "timezone": "browser",
  "refresh": "1m",
  "schemaVersion": 38,
  "graphTooltip": 1,
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "current": { "text": "Thanos", "value": "Thanos" },
        "hide": 0,
        "refresh": 1
      }
    ]
  },
  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "IoT Core – Maestro MQTT",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },

    {
      "id": 2,
      "type": "timeseries",
      "title": "IoT Core – Connect Success / AuthError",
      "description": "If no data appears, verify that iot_log_level is not DISABLED and Maestro has connected to the IoT endpoint.",
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "aws_iot_connect_success_sum{dimension_Protocol=\"MQTT\"}",
          "legendFormat": "Connect.Success"
        },
        {
          "refId": "B",
          "expr": "aws_iot_connect_autherror_sum{dimension_Protocol=\"MQTT\"}",
          "legendFormat": "Connect.AuthError"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Connect.AuthError" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "id": 3,
      "type": "timeseries",
      "title": "IoT Core – PublishIn / PublishOut Success",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "aws_iot_publish_in_success_sum{dimension_Protocol=\"MQTT\"}",
          "legendFormat": "PublishIn.Success"
        },
        {
          "refId": "B",
          "expr": "aws_iot_publish_out_success_sum{dimension_Protocol=\"MQTT\"}",
          "legendFormat": "PublishOut.Success"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "id": 4,
      "type": "row",
      "title": "NAT Gateway",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 }
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "NAT Gateway – Packet Drops & Port Allocation Errors",
      "description": "These metrics only emit when events occur. Zero values from nilToZero mean no drops or port exhaustion — that is the healthy state.",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "aws_natgateway_packets_drop_count_sum",
          "legendFormat": "{{ dimension_NatGatewayId }} drops"
        },
        {
          "refId": "B",
          "expr": "aws_natgateway_error_port_allocation_sum",
          "legendFormat": "{{ dimension_NatGatewayId }} port err"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "NAT Gateway – Active Connection Count",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "aws_natgateway_active_connection_count_maximum",
          "legendFormat": "{{ dimension_NatGatewayId }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "id": 7,
      "type": "row",
      "title": "Amazon MQ – HyperFleet RabbitMQ",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 }
    },

    {
      "id": 8,
      "type": "stat",
      "title": "Messages Ready",
      "description": "Messages queued and waiting for consumers. A sustained climb means consumers are falling behind.",
      "gridPos": { "x": 0, "y": 19, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(aws_amazonmq_message_count_average)",
          "legendFormat": "Messages Ready"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "green" }, { "value": 1000, "color": "yellow" }, { "value": 10000, "color": "red" }]
          }
        }
      }
    },

    {
      "id": 9,
      "type": "stat",
      "title": "Unacknowledged Messages",
      "description": "Messages delivered to consumers but not yet acknowledged. High values indicate slow or stalled consumers.",
      "gridPos": { "x": 6, "y": 19, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(aws_amazonmq_message_unacknowledged_count_average)",
          "legendFormat": "Unacknowledged"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "green" }, { "value": 500, "color": "yellow" }, { "value": 5000, "color": "red" }]
          }
        }
      }
    },

    {
      "id": 10,
      "type": "stat",
      "title": "Consumers",
      "gridPos": { "x": 12, "y": 19, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(aws_amazonmq_consumer_count_average)",
          "legendFormat": "Consumers"
        }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "none" } }
    },

    {
      "id": 11,
      "type": "stat",
      "title": "Queues",
      "gridPos": { "x": 18, "y": 19, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "aws_amazonmq_queue_count_average",
          "legendFormat": "Queues"
        }
      ],
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "none" } }
    },

    {
      "id": 12,
      "type": "timeseries",
      "title": "MQ – Message Counts",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (dimension_Broker) (aws_amazonmq_message_count_average)",
          "legendFormat": "{{ dimension_Broker }} Ready"
        },
        {
          "refId": "B",
          "expr": "sum by (dimension_Broker) (aws_amazonmq_message_unacknowledged_count_average)",
          "legendFormat": "{{ dimension_Broker }} Unacknowledged"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "id": 13,
      "type": "timeseries",
      "title": "MQ – Network Throughput",
      "gridPos": { "x": 0, "y": 33, "w": 24, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (dimension_Broker) (aws_amazonmq_network_in_average)",
          "legendFormat": "{{ dimension_Broker }} In"
        },
        {
          "refId": "B",
          "expr": "sum by (dimension_Broker) (aws_amazonmq_network_out_average)",
          "legendFormat": "{{ dimension_Broker }} Out"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "id": 14,
      "type": "row",
      "title": "ACM – Certificate Expiry",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 43, "w": 24, "h": 1 }
    },

    {
      "id": 15,
      "type": "stat",
      "title": "Days to Expiry",
      "description": "ACM publishes this metric once per day. Widen the time range to 7d or 30d if no data appears. Alert threshold: yellow at 30 days, red at 7 days.",
      "gridPos": { "x": 0, "y": 44, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "min(aws_certificatemanager_days_to_expiry_minimum)",
          "legendFormat": "Days to Expiry"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 72 }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 7, "color": "yellow" },
              { "value": 30, "color": "green" }
            ]
          }
        }
      }
    },

    {
      "id": 16,
      "type": "timeseries",
      "title": "Certificate Days to Expiry – Trend",
      "description": "Should decrease by 1 per day. A flat line means ACM stopped publishing — check certificate status in the console.",
      "gridPos": { "x": 6, "y": 44, "w": 18, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "aws_certificatemanager_days_to_expiry_minimum",
          "legendFormat": "{{ name }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 7, "color": "yellow" },
              { "value": 30, "color": "green" }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    }

  ],
  "annotations": { "list": [] },
  "links": []
}
