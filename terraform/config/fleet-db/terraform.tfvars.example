# =============================================================================
# Fleet-DB Infrastructure Configuration Template
# =============================================================================
# Fleet-DB is a workerless EKS cluster whose kube-apiserver acts as the
# database for hyperfleet CRDs. No workloads are scheduled on it.
#
# IMPORTANT: Never commit terraform.tfvars to git - it's in .gitignore

# Cluster identifier
fleet_db_id = "fleet-db"

# Environment
environment = "integration"

# AWS Region
region = "us-east-1"

# Container image for bastion and ECS bootstrap
container_image = "public.ecr.aws/xxx/rosa-regional-platform:latest"

# Tagging Configuration
app_code      = "APP001"
service_phase = "development"
cost_center   = "123"

# =============================================================================
# ArgoCD Bootstrap Configuration
# =============================================================================

repository_url    = "https://github.com/openshift-online/rosa-regional-platform"
repository_branch = "main"

# =============================================================================
# Bastion Configuration (Optional)
# =============================================================================

# enable_bastion = true
